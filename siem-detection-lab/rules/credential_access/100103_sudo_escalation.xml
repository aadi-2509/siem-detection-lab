<!--
  Sudo Privilege Escalation Detection
  MITRE ATT&CK: T1548.003 — Abuse Elevation Control Mechanism: Sudo
  Tactic: Privilege Escalation

  Wazuh built-in rule 5402 fires on any sudo event.
  We layer on top of it to specifically catch escalation to root
  and unauthorized sudo attempts.
-->

<group name="local,syslog,sudo,">

  <!-- Sudo to root — always worth logging -->
  <rule id="100110" level="8">
    <if_sid>5402</if_sid>
    <field name="dstuser">^root$</field>
    <description>Sudo privilege escalation to root by $(srcuser)</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- Sudo command running a shell — strong indicator of abuse -->
  <rule id="100111" level="12">
    <if_sid>5402</if_sid>
    <field name="dstuser">^root$</field>
    <regex>/bin/bash|/bin/sh|/bin/zsh|python -c|perl -e</regex>
    <description>Sudo used to spawn a shell as root — possible privilege abuse by $(srcuser)</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- Repeated sudo failures — someone is probing -->
  <rule id="100112" level="10" frequency="3" timeframe="60">
    <if_sid>5401</if_sid>
    <same_source_user />
    <description>Repeated sudo failures: $(srcuser) failed 3+ times in 60s</description>
    <group>authentication_failures,</group>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

</group>
