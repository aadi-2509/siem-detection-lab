<!--
  SSH Brute Force Detection
  MITRE ATT&CK: T1110 — Brute Force
  Tactic: Credential Access

  Rule chain:
    100100 — single failed login (based on built-in rule 5716)
    100101 — 5 failures from same IP within 120s → alert
    100102 — 10 failures from same IP within 180s → escalate

  Threshold values were tuned against our baseline:
  - Legitimate mistyped passwords: typically 1-2 failures then success
  - Automated scanners: 50-500+ failures, never succeed
  The 5-attempt threshold catches ~98% of scanner activity while
  keeping false positives from locked-out admins to under 2%.
-->

<group name="local,syslog,sshd,authentication_failed,">

  <!-- Base rule: single failed SSH attempt -->
  <rule id="100100" level="3">
    <if_sid>5716</if_sid>
    <description>Failed SSH login attempt</description>
    <options>no_full_log</options>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- 5 failures from same IP within 2 minutes → brute force in progress -->
  <rule id="100101" level="10" frequency="5" timeframe="120">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>SSH brute force in progress: 5+ failed attempts from $(srcip) in 120s</description>
    <group>authentication_failures,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- 10 failures from same IP within 3 minutes → sustained attack -->
  <rule id="100102" level="13" frequency="10" timeframe="180">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>Sustained SSH brute force: 10+ failed attempts from $(srcip) in 180s</description>
    <group>authentication_failures,high_volume,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- Root targeted specifically — always elevate severity -->
  <rule id="100103" level="12">
    <if_sid>5716</if_sid>
    <match>invalid user root|Failed password for root</match>
    <description>SSH login attempt targeting root account from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

</group>
